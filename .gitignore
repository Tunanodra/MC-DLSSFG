# --- IDE / OS ---
.idea/
.vscode/
*.iml
*.ipr
*.iws
.DS_Store
Thumbs.db
Desktop.ini
*~

# --- Gradle / Java build ---
.gradle/
**/build/
out/
bin/
*.class
hs_err_pid*
replay_pid*

# --- Local run / output ---
run/
runs/
logs/
build_jars/
build.properties
.architectury-transformer/

# --- Native build artifacts ---
native/cpp/build/
native/cpp/build*/
native/cpp/output/
native/cpp/**/bin/
native/cpp/**/libraries/
*.pdb
*.o
*.obj
*.a
*.lib
*.dll
*.so
*.dylib
*.exe

# Keep Gradle wrapper only
!gradle/wrapper/gradle-wrapper.jar

# Local dependency jar (needed to build; keep tracked if already present)
!libs/*.jar

# --- Bundled runtime natives (generated by native:buildNative) ---
common/src/main/resources/lib/

# --- Third-party SDKs: use git submodules, do not vendor binaries ---
native/cpp/SRNativeMain/third_party/freetype/
native/cpp/SRNativeMain/third_party/glslang/
native/cpp/SRNativeFSR/SDK/
native/cpp/SRNativeXeSS/third_party/XeSS/
native/cpp/SRNativeNGX/third_party/DLSS/

# Streamline: headers only; ignore prebuilt libs
native/cpp/third_party/Streamline/lib/

# --- Debug tooling (install RenderDoc yourself) ---
renderdoc/*.dll
renderdoc/*.so
renderdoc/*.jar

# --- Generated JNI headers ---
native/cpp/SRNativeMain/include/com_*.h

# --- Huge optional font (keep MaterialSymbols only) ---
**/assets/**/font/Font.ttf

# --- Misc local / agent junk ---
__pycache__/
*.log
.claude/
.codemoss/
AGENTS.md.bak
fsr2-win64/
fsr2_win64/
